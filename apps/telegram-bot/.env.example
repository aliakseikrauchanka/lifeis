# STOP: Get this from @BotFather on Telegram first.
# Open Telegram → search @BotFather → send /newbot → follow prompts → copy token
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# Generate locally: openssl rand -hex 32
# Must match TELEGRAM_BOT_API_KEY in entry-server
TELEGRAM_BOT_API_KEY=your-secret-api-key
# Your backend URL. For Docker Compose use http://entry-server:3000 (set automatically)
BE_URL=http://localhost:3000
# Optional: whitelist chat/group IDs. Comma-separated (e.g. 123456789,-987654321).
# If empty, all chats can use the bot. To get your chat ID: forward a message to @userinfobot
# TELEGRAM_ALLOWED_CHAT_IDS=123456789,-987654321

# Optional: transcription language (e.g. en, ru)
# TRANSCRIPTION_LANGUAGE=ru
