# Telegram bot (voice → transcription via entry-server API)
FROM node:22-alpine3.19

WORKDIR /app

# Install dependencies
COPY package.json package-lock.json ./
COPY nx.json ./
RUN npm install --legacy-peer-deps

# Copy source (apps/telegram-bot, configs)
COPY apps/telegram-bot ./apps/telegram-bot
COPY tsconfig.base.json ./
COPY jest.preset.js ./

# Build telegram-bot
RUN npx nx run telegram-bot:build --configuration=production --skip-nx-cache

# Start the bot
CMD ["node", "./dist/apps/telegram-bot/main.js"]
